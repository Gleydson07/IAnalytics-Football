# API-Football (dashboard.api-football.com)
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=sua_key_aqui

# Provider de IA em uso: "openai" (default) ou "anthropic"
AI_PROVIDER=openai

# OpenAI (platform.openai.com) — provider padrão
OPENAI_API_KEY=sua_key_aqui
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (console.anthropic.com) — alternativa
ANTHROPIC_API_KEY=sua_key_aqui
ANTHROPIC_MODEL=claude-sonnet-4-6

# Redis Upstash (console.upstash.com → Redis → REST API)
# Opcional em dev: sem isso o app roda sem cache (consome mais quota da API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Postgres (docker-compose up -d) — depois migra p/ Supabase/Neon
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/football_scout?schema=public"
