generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PreferredLeague {
  id        String   @id @default(uuid())
  leagueId  Int      @unique @map("league_id")
  name      String
  country   String
  season    Int
  logo      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("preferred_leagues")
}
